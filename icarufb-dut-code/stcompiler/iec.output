   76 ConstAssig: T_ID T_ASSIGNMENT T_NUMBER T_SEMICOLON

   77 $@17: %empty

   78 EventConnListContainer: T_EVENT_CONNECTIONS $@17 ConnectionList T_END_CONNECTIONS

   79 $@18: %empty

   80 DataConnListContainer: T_DATA_CONNECTIONS $@18 ConnectionList T_END_CONNECTIONS

   81 ConnectionList: ConnectionList Connection
   82               | Connection

   83 Connection: T_ID T_POINT T_ID T_TO T_ID T_POINT T_ID T_SEMICOLON

   84 AlgorithmList: %empty
   85              | AlgorithmList Algorithm

   86 $@19: %empty

   87 Algorithm: T_ALGORITHM T_ID T_IN T_ID T_TWO_POINTS $@19 StatementList T_END_ALGORITHM

   88 StatementList: %empty
   89              | StatementList Assignment
   90              | StatementList If_stat
   91              | StatementList While_stat
   92              | StatementList Call_stat T_SEMICOLON
   93              | StatementList AsmBlock

   94 AsmBlock: T_ASM AsmCode T_END_ASM

   95 AsmCode: %empty
   96        | AsmCode Instruction

   97 Instruction: T_LOAD AsmIdNum
   98            | T_CONST T_NUMBER
