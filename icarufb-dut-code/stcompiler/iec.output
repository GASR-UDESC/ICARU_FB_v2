  109             | T_NUMBER
  110             | T_ADD T_NUMBER

  111 AsmIdNum: T_ID
  112         | T_NUMBER
  113         | T_ADD T_NUMBER

  114 Call_stat: T_BI_SET_REG T_OP Expr T_COMA Expr T_CP
  115          | T_BI_GET_REG T_OP Expr T_CP
  116          | T_BI_GET_REG_REAL T_OP Expr T_CP

  117 While_stat: T_WHILE Expr T_DO StatementList T_END_WHILE T_SEMICOLON

  118 $@20: %empty

  119 If_stat: T_IF Expr T_THEN $@20 StatementList IFContinue

  120 IFContinue: T_END_IF T_SEMICOLON

  121 $@21: %empty

  122 IFContinue: T_ELSE $@21 StatementList T_END_IF T_SEMICOLON

  123 $@22: %empty

  124 $@23: %empty

  125 IFContinue: T_ELSIF $@22 Expr T_THEN $@23 StatementList IFContinue

  126 Assignment: T_ID T_ASSIGNMENT Expr T_SEMICOLON

  127 M: %empty

  128 Expr: Logical_Expr

  129 Logical_Expr: Logical_Expr T_OR M Logical_Expr_p2
  130             | Logical_Expr_p2

  131 Logical_Expr_p2: Logical_Expr_p2 T_AND M Logical_Expr_p1
  132                | Logical_Expr_p1

  133 Logical_Expr_p1: %empty
  134                | Relational_Expr

  135 Relational_Expr: Relational_Expr Relational_Operator Arithmetic_Expr
  136                | Arithmetic_Expr

  137 Arithmetic_Expr: Arithmetic_Expr T_ADD Arithmetic_Expr_p1
  138                | Arithmetic_Expr T_SUB Arithmetic_Expr_p1
  139                | Arithmetic_Expr_p1

  140 Arithmetic_Expr_p1: Arithmetic_Expr_p1 T_MUL Factor
  141                   | Arithmetic_Expr_p1 T_DIV Factor
  142                   | Factor

  143 Factor: T_NUMBER
  144       | T_NUMBER_REAL
  145       | T_OP Expr T_CP
  146       | T_NOT Factor
  147       | T_ID
  148       | Call_stat

  149 Relational_Operator: T_GT
