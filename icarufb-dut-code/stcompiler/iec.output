   14 $@7: %empty

   15 $@8: %empty

   16 FunctionBlock: T_FUNCTION_BLOCK T_ID $@7 EventInputListContainer EventOutputListContainer EcStatesListContainer EcTransListContainer VarInputListContainer VarOutputListContainer VarListContainer $@8 FbContinue T_END_FUNCTION_BLOCK

   17 FbContinue: AlgorithmList
   18           | FbsListContainer EventConnListContainer DataConnListContainer

   19 EventInputListContainer: %empty
