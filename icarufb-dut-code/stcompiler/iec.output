   54 VarDecl: T_ID T_TWO_POINTS T_ID VarDeclAssig T_SEMICOLON

   55 VarDeclAssig: %empty
   56             | T_ASSIGNMENT T_NUMBER

   57 System: T_SYSTEM T_ID DeviceList T_END_SYSTEM

   58 DeviceList: Device DeviceList
   59           | Device

   60 $@13: %empty

   61 Device: T_DEVICE T_ID T_TWO_POINTS T_ID $@13 ResourceList T_END_DEVICE

   62 $@14: %empty

   63 Device: T_DEVICE T_ID T_TWO_POINTS T_ID T_OP T_CP $@14 ResourceList T_END_DEVICE

   64 ResourceList: ResourceList Resource
   65             | Resource

   66 $@15: %empty

   67 Resource: T_RESOURCE T_ID T_TWO_POINTS T_ID T_OP T_CP $@15 FbsListContainer EventConnListContainer DataConnListContainer T_END_RESOURCE

   68 FbsListContainer: T_FBS FbsList T_END_FBS

   69 FbsList: FbsList FbsDeclaration
   70        | FbsDeclaration

   71 FbsDeclaration: T_ID T_TWO_POINTS T_ID T_SEMICOLON

   72 $@16: %empty

