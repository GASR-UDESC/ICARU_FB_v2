SYSTEM TEMPERATURE_CONTROLLER (*  *)
	DEVICE DV1 : BOARD41(
			
		)
		RESOURCE RS1: EMB_RES()
			FBS
				SENSOR: IO_READER(
					SD_1 := 40;
					);
				PUB_1 : PUBLISHER(
					PARAMS := 10;
					);
			END_FBS

			EVENT_CONNECTIONS
				START.COLD TO SENSOR.REQ;
				SENSOR.RSP TO PUB_1.REQ;	
			END_CONNECTIONS

			DATA_CONNECTIONS
				SENSOR.RD_1 TO PUB_1.SD_1;
			END_CONNECTIONS

		END_RESOURCE
	END_DEVICE
	DEVICE DV2 : BOARD41(

		)
		RESOURCE RS1: EMB_RES()
			FBS
				SUB_1 : SUBSCRIBER(
					PARAMS := 10;
				);
				CONTROL: TMP_CONTROL;
				RELE : IO_WRITER(
					SD_1 := 1;
				);
			END_FBS

			EVENT_CONNECTIONS
				START.COLD TO CONTROL.INIT;
				SUB_1.RSP TO CONTROL.ACT;
			END_CONNECTIONS

			DATA_CONNECTIONS
				SUB_1.RD_1 TO CONTROL.TMP;
				CONTROL.Q TO RELE.SD_1;
			END_CONNECTIONS

		END_RESOURCE
	END_DEVICE
END_SYSTEM
